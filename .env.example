# OpenAI API Key (required for LLM-based agents)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Set to false to force deterministic rule/template fallbacks without outbound LLM calls
LLM_ENABLED=true

# Log level
LOG_LEVEL=INFO

# ChromaDB persistence path
CHROMA_PATH=./chroma_data

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000

