    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Process the sprint review reminder\\n\",\n",
    "    \"r = client.post(\\\"/inbox/process\\\", json={\\\"email_id\\\": \\\"email-006\\\"})\\n\",\n",
    "    \"result = r.json()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"PROCESSING RESULT: Sprint Reminder\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(f\\\"Status: {result['status']}\\\")\\n\",\n",
    "    \"if result.get('classification'):\\n\",\n",
    "    \"    cls = result['classification']\\n\",\n",
    "    \"    print(f\\\"Intent: {cls.get('intent')} | Priority: {cls.get('priority')}\\\")\\n\",\n",
    "    \"if result.get('follow_up'):\\n\",\n",
    "    \"    fu = result['follow_up']\\n\",\n",
