    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# View current metrics\\n\",\n",
    "    \"r = client.get(\\\"/metrics\\\")\\n\",\n",
    "    \"metrics = r.json()\\n\",\n",
    "    \"print(\\\"📊 System Metrics\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 40)\\n\",\n",
    "    \"print(\\\"\\\\nCounters:\\\")\\n\",\n",
    "    \"for k, v in metrics['counters'].items():\\n\",\n",
    "    \"    if v > 0:\\n\",\n",
    "    \"        print(f\\\"  {k}: {v}\\\")\\n\",\n",
    "    \"print(\\\"\\\\nLatencies:\\\")\\n\",\n",
