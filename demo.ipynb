    "    \"        print(f\\\"  {k}: avg={v['avg_ms']:.0f}ms, p50={v['p50_ms']:.0f}ms, max={v['max_ms']:.0f}ms\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# View processing traces\\n\",\n",
    "    \"r = client.get(\\\"/traces\\\")\\n\",\n",
    "    \"traces = r.json()\\n\",\n",
    "    \"print(f\\\"📍 Total traces: {traces['total']}\\\\n\\\")\\n\",\n",
    "    \"for trace in traces['traces']:\\n\",\n",
    "    \"    print(f\\\"Run: {trace['run_id']} ({trace['total_spans']} spans)\\\")\\n\",\n",
    "    \"    for span in trace['spans']:\\n\",\n",
    "    \"        status_icon = '✅' if span['status'] == 'success' else '❌'\\n\",\n",
    "    \"        print(f\\\"  {status_icon} [{span['span_type']}] {span['name']} — {span['duration_ms']:.0f}ms\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## Summary\\n\",\n",
    "    \"\\n\",\n",
    "    \"This demo showed:\\n\",\n",
    "    \"- ✅ **Agent architecture**: Orchestrator (LangGraph StateGraph) coordinating reader, summarizer, drafter, and scheduler agents\\n\",\n",
    "    \"- ✅ **Email capabilities**: Read, classify, label, summarize, draft replies, schedule follow-ups\\n\",\n",
    "    \"- ✅ **Human-in-the-loop**: All outgoing actions require approval via `/approvals` endpoints\\n\",\n",
    "    \"- ✅ **Memory**: Short-term (LangGraph state) + Long-term (hybrid JSON/ChromaDB with semantic search)\\n\",\n",
    "    \"- ✅ **Feedback loop**: User edits/rejections stored in memory to evolve future behavior\\n\",\n",
    "    \"- ✅ **Structured I/O**: All interactions use Pydantic-validated JSON schemas\\n\",\n",
    "    \"- ✅ **Observability**: Structured logging, span-based tracing, and metrics with latency histograms\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
