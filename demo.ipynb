    "    \"print(f\\\"\\\\nPending Approvals: {len(result.get('pending_approvals', []))}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
