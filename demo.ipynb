    "   \"source\": [\n",
    "    \"# 📧 Email Assistant — End-to-End Demo\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook demonstrates the full flow of the intelligent email assistant:\\n\",\n",
    "    \"1. **Seed data** — Load sample emails, contacts, and org facts\\n\",\n",
    "    \"2. **Browse inbox** — View incoming emails\\n\",\n",
    "    \"3. **Process emails** — Run through the agent orchestrator pipeline\\n\",\n",
    "    \"4. **Review approvals** — Human-in-the-loop approval flow\\n\",\n",
    "    \"5. **Memory queries** — Search long-term memory\\n\",\n",
    "    \"6. **Metrics & traces** — Observe system behavior\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Prerequisites:** Start the server first with `docker compose up --build` or `uvicorn app.main:app --port 8000`\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import httpx\\n\",\n",
    "    \"import json\\n\",\n",
