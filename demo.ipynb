    "    \"r = client.post(\\\"/reset\\\")\\n\",\n",
    "    \"print(\\\"🔄 System reset:\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Browse Inbox\"\n",
