    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Health check\\n\",\n",
    "    \"r = client.get(\\\"/health\\\")\\n\",\n",
    "    \"print(\\\"✅ Server status:\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
