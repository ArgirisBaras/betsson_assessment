    "    \"print(\\\"🔍 Contact search: 'infrastructure production issues'\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Search org facts\\n\",\n",
    "    \"r = client.get(\\\"/memory/org-facts/search\\\", params={\\\"q\\\": \\\"B2B API integration\\\"})\\n\",\n",
    "    \"print(\\\"🔍 Org facts search: 'B2B API integration'\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Search preferences (should include feedback from our edit above)\\n\",\n",
    "    \"r = client.get(\\\"/memory/preferences/search\\\", params={\\\"q\\\": \\\"reply tone friendly\\\"})\\n\",\n",
    "    \"print(\\\"🔍 Preferences search: 'reply tone friendly'\\\")\\n\",\n",
    "    \"print(\\\"(Should include learned feedback from the edited approval above)\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Add a new preference\\n\",\n",
    "    \"r = client.post(\\\"/memory/preferences\\\", json={\\n\",\n",
    "    \"    \\\"key\\\": \\\"signature\\\",\\n\",\n",
    "    \"    \\\"value\\\": \\\"Best regards,\\\\nAI/ML Team\\\",\\n\",\n",
    "    \"    \\\"description\\\": \\\"Default email signature\\\"\\n\",\n",
    "    \"})\\n\",\n",
    "    \"print(\\\"➕ Added preference:\\\")\\n\",\n",
    "    \"pp(r.json())\"\n",
