    "    \"client = httpx.Client(base_url=BASE_URL, timeout=30.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def pp(data):\\n\",\n",
    "    \"    \\\"\\\"\\\"Pretty print JSON response.\\\"\\\"\\\"\\n\",\n",
    "    \"    print(json.dumps(data, indent=2, default=str))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Health Check & Reset\"\n",
