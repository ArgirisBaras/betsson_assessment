    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# List all emails in inbox\\n\",\n",
    "    \"r = client.get(\\\"/inbox/\\\")\\n\",\n",
    "    \"inbox = r.json()\\n\",\n",
    "    \"print(f\\\"Total emails: {inbox['total']}\\\\n\\\")\\n\",\n",
    "    \"for email in inbox['emails']:\\n\",\n",
