    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Human-in-the-Loop: Review & Approve Actions\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# List all pending approvals\\n\",\n",
    "    \"r = client.get(\\\"/approvals/\\\")\\n\",\n",
    "    \"approvals = r.json()\\n\",\n",
    "    \"print(f\\\"Total approvals: {approvals['total']}\\\\n\\\")\\n\",\n",
    "    \"for apr in approvals['approvals']:\\n\",\n",
    "    \"    print(f\\\"  [{apr['approval_id']}] {apr['action_type']} — {apr['status']}\\\")\\n\",\n",
    "    \"    print(f\\\"    {apr['description']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Approve the first pending action\\n\",\n",
    "    \"if approvals['approvals']:\\n\",\n",
    "    \"    first_id = approvals['approvals'][0]['approval_id']\\n\",\n",
    "    \"    print(f\\\"✅ Approving: {first_id}\\\")\\n\",\n",
    "    \"    r = client.post(f\\\"/approvals/{first_id}/decide\\\", json={\\n\",\n",
    "    \"        \\\"decision\\\": \\\"approved\\\",\\n\",\n",
    "    \"        \\\"feedback\\\": \\\"Looks good, send it.\\\"\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"    pp(r.json())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Edit and approve the second action (demonstrates the feedback loop)\\n\",\n",
    "    \"if len(approvals['approvals']) > 1:\\n\",\n",
    "    \"    second_id = approvals['approvals'][1]['approval_id']\\n\",\n",
    "    \"    original_payload = approvals['approvals'][1]['payload']\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    # Modify the draft body\\n\",\n",
    "    \"    edited_payload = dict(original_payload)\\n\",\n",
    "    \"    if 'body' in edited_payload:\\n\",\n",
    "    \"        edited_payload['body'] = edited_payload['body'] + \\\"\\\\n\\\\nP.S. Let me know if you need anything else.\\\"\\n\",\n",
    "    \"    \\n\",\n",
    "    \"    print(f\\\"✏️ Editing and approving: {second_id}\\\")\\n\",\n",
    "    \"    r = client.post(f\\\"/approvals/{second_id}/decide\\\", json={\\n\",\n",
    "    \"        \\\"decision\\\": \\\"edited\\\",\\n\",\n",
    "    \"        \\\"edited_payload\\\": edited_payload,\\n\",\n",
    "    \"        \\\"feedback\\\": \\\"Added a closing line — prefer friendlier sign-offs.\\\"\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"    pp(r.json())\\n\",\n",
    "    \"    print(\\\"\\\\n💡 This edit was stored in long-term memory to improve future drafts.\\\")\"\n",
    "   ]\n",
    "  },\n",
