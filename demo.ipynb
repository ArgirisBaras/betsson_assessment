    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Process the FYI policy update\\n\",\n",
    "    \"r = client.post(\\\"/inbox/process\\\", json={\\\"email_id\\\": \\\"email-005\\\"})\\n\",\n",
    "    \"result = r.json()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
    "    \"print(\\\"PROCESSING RESULT: FYI Policy Update\\\")\\n\",\n",
    "    \"print(\\\"=\\\" * 60)\\n\",\n",
